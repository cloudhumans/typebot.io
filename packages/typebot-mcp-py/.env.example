# Base URL of the Typebot viewer API. The chat endpoints live under /api/v1.
TYPEBOT_API_BASE_URL=http://localhost:3003

# Bearer token for authenticated calls. Generate one in the builder UI.
TYPEBOT_API_TOKEN=replace-me

# Default tenant slug forwarded as the `x-tenant` header.
TYPEBOT_TENANT=acme-inc

# HTTP request timeout (seconds).
TYPEBOT_TIMEOUT_SECONDS=30

# Set to `true` to forward `X-Include-Drafts: true` on discovery requests.
TYPEBOT_INCLUDE_DRAFTS=false

# Builder API base URL — used by management tools (typebot CRUD, results,
# analytics, folders). Falls back to TYPEBOT_API_BASE_URL when unset.
TYPEBOT_BUILDER_BASE_URL=http://localhost:3002

# Set to `true` to register mutating tools (create/update/delete/publish).
# Default false — safest for shared MCP deployments.
TYPEBOT_ALLOW_WRITES=false
